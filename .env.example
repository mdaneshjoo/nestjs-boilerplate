# ── App ───────────────────────────────────────────────────────
PORT=3100
MODE=DEV                       # DEV | PROD
APP_NAME=Boilerplate
CLIENT_URL=http://localhost:3000

# ── Database (Postgres) ───────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=boilerplate
DB_USERNAME=postgres
DB_PASSWORD=postgres
SYNC=false                     # true only in local dev

# ── Auth (JWT) ────────────────────────────────────────────────
SECRET=change-me-to-a-long-random-string
EXPIRE=1d                      # e.g. 60s, 15m, 1h, 1d, 1y

# ── Mail (SMTP) ───────────────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.com

# ── Sentry (optional — leave blank to disable) ────────────────
SENTRY_DSN=

# ── Logger ────────────────────────────────────────────────────
# Per-destination minimum level. Set to "off" to disable the destination.
# Valid levels: debug | info | warn | error | fatal | off
LOG_LEVEL_CONSOLE=info
LOG_LEVEL_FILE=warn
LOG_LEVEL_DB=off

# File rotation (pino-roll)
LOG_FILE_DIR=logs
LOG_FILE_ROTATE_SIZE=30m
LOG_FILE_ROTATE_FREQUENCY=daily

# Postgres destination (uses the same DB_* connection)
LOG_DB_TABLE=app_logs
LOG_DB_BATCH_SIZE=100
LOG_DB_FLUSH_MS=1000
